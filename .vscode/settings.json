{
    "bibtex-tidy.options": {
        "blankLines": true,
        "curly": true,
        "enclosingBraces": true,
        "sort": ["-year", "author", "title"],
        "sortFields": true
    },
    "liveServer.settings.root": "/doc/dist",
    "myst.preview.extensions": [
        "dollarmath",
        "colon_fence"
    ],
    "python.testing.cwd": "${workspaceFolder}/e2e-tests",
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "search.exclude": {
        "**/.idea": true,
        "**/.nextflow": true,
        "**/.venv": true,
        "**/.pytest_cache": true,
        "doc/dist": true
    },
    "search.useIgnoreFiles": false
}
